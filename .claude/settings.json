{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/StandardEq.sh",
            "statusMessage": "Enforcing LaTeX equation style"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/SmartSync.sh",
            "statusMessage": "Syncing changes between machines",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
